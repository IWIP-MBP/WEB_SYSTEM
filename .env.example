# Copy to .env and fill in real values. Do NOT commit .env.

# PostgreSQL credentials
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=hr_system

# JWT signing key. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-value

# Comma-separated list of allowed origins. Never use "*" in production.
CORS_ORIGINS=http://localhost,http://localhost:8501

# Initial admin password used only when the admin account is first created.
# If left empty, a random password is generated and logged once at startup.
ADMIN_INITIAL_PASSWORD=
